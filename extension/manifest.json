{
  "manifest_version": 3,
  "name": "Pass Vault",
  "version": "0.1.0",
  "description": "Pass Vault — secure password autofill for your organization.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus", "clipboardWrite"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_title": "Pass Vault",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    { "resources": ["autofill-frame.html"], "matches": ["<all_urls>"] }
  ]
}
